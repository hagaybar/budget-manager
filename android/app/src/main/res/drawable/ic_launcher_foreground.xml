<?xml version="1.0" encoding="utf-8"?>
<!--
    Budget Manager adaptive icon foreground.
    Design: A clean, stylized wallet with a card slot and three ascending
    bar-chart lines — communicates "finance + growth" at a glance.
    White on the Deep Trust Blue (#2B5EA7) background.
    Canvas: 108x108dp with safe zone inset 18dp each side (72x72 visible area).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Wallet body — rounded rectangle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M30,36
            Q30,32 34,32
            L74,32
            Q78,32 78,36
            L78,72
            Q78,76 74,76
            L34,76
            Q30,76 30,72
            Z" />

    <!-- Wallet flap fold — subtle horizontal divider near top -->
    <path
        android:fillColor="#2B5EA7"
        android:fillAlpha="0.15"
        android:pathData="M30,43 L78,43 L78,45 L30,45 Z" />

    <!-- Card slot on right side — rounded notch -->
    <path
        android:fillColor="#2B5EA7"
        android:fillAlpha="0.18"
        android:pathData="
            M65,49
            Q65,47 67,47
            L78,47
            L78,59
            L67,59
            Q65,59 65,57
            Z" />

    <!-- Clasp dot inside card slot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M71,53m-2.2,0a2.2,2.2 0,1 1,4.4 0a2.2,2.2 0,1 1,-4.4 0" />

    <!-- Three ascending bars (mini chart) — inside wallet body -->
    <path
        android:fillColor="#2B5EA7"
        android:fillAlpha="0.22"
        android:pathData="M37,70 L37,63 L41,63 L41,70 Z" />
    <path
        android:fillColor="#2B5EA7"
        android:fillAlpha="0.22"
        android:pathData="M44,70 L44,57 L48,57 L48,70 Z" />
    <path
        android:fillColor="#2B5EA7"
        android:fillAlpha="0.22"
        android:pathData="M51,70 L51,51 L55,51 L55,70 Z" />

</vector>
